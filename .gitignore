# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# NOTE: jobs_db.json is intentionally NOT ignored.
